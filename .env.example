# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: override base URL for Groq / Azure / local proxy
# Groq:  OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_MODEL=llama3-70b-8192
# Ollama: OPENAI_BASE_URL=http://localhost:11434/v1       OPENAI_MODEL=llama3
OPENAI_BASE_URL=

# Optional tracing providers
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
